{
  "id": "np-content-13410",
  "type": "statute",
  "title": "घीय्‌आकस्मिक्‌कोष्‌ऐन, २०७४",
  "title_en": "Federal Contingency Fund Act 2074",
  "short_name": "Federal Contingency Fund Ac...",
  "status": "in_force",
  "issued_date": "",
  "in_force_date": "",
  "url": "https://lawcommission.gov.np/content/13410/federal-contingency-fund-act--2074",
  "provisions": [
    {
      "provision_ref": "1",
      "section": "Paragraph 1",
      "title": "",
      "content": "सङ्‌\nघीय्‌आकस्मिक्‌कोष्‌ऐन, २०७४"
    },
    {
      "provision_ref": "2",
      "section": "Paragraph 2",
      "title": "",
      "content": "प्रिाणीकरण्‌तथा्‌प्रकास्ित्‌मिमत्‌"
    },
    {
      "provision_ref": "3",
      "section": "Paragraph 3",
      "title": "",
      "content": "सं वत््‌२०७४्‌सालको्‌ऐन्‌नं.्‌९"
    },
    {
      "provision_ref": "4",
      "section": "Paragraph 4",
      "title": "",
      "content": "आकस्मिक्‌कोष्‌सम्बन्धी्‌कानूनलाई्‌सं िोधन्‌र्‌एकीकरण्‌गने्‌सम्बन्धिा्‌व्यवमथा्‌गनन्‌बनेको्‌\nऐन"
    },
    {
      "provision_ref": "5",
      "section": "Paragraph 5",
      "title": "",
      "content": "प्रमतावनााः्‌ आकस्मिक्‌ कोषको्‌ मथापना्‌ र्‌ सञ््‌चालन्‌ सम्बन्धी्‌ प्रचमलत्‌ कानूनलाई्‌ सं िोधन्‌ र्‌\nएकीकरण्‌गरी्‌सियानुकूल्‌बनाउन्‌वाञ्छनीय्‌भएकोले ,"
    },
    {
      "provision_ref": "6",
      "section": "Paragraph 6",
      "title": "",
      "content": "नेपालको्‌सं ववधानको्‌धारा्‌२९६्‌को्‌उपधारा्‌(१)्‌बिोस्ििको्‌व्यवमथावपका–सं सदले ्‌यो्‌\nऐन्‌बनाएको्‌छ्‌।"
    },
    {
      "provision_ref": "7",
      "section": "Paragraph 7",
      "title": "",
      "content": "१.्‌    संस्िप्त्‌ नाि्‌ र्‌ प्रारम्भाः्‌ (१)्‌ यस्‌ ऐनको्‌ नाि्‌ “सङघीय्‌ आकस्मिक्‌ कोष्‌ ऐन, २०७४”्‌\nरहेको्‌छ्‌।"
    },
    {
      "provision_ref": "8",
      "section": "Paragraph 8",
      "title": "",
      "content": "(२)्‌यो्‌ऐन्‌तुरुन्त्‌प्रारम्भ्‌हुनेछ्‌।"
    },
    {
      "provision_ref": "9",
      "section": "Paragraph 9",
      "title": "",
      "content": "२.्‌    पररभाषााः्‌ववषय्‌वा्‌प्रसङ्गले्‌अको्‌अथन्‌नलागेिा्‌यस्‌ऐनिा,–"
    },
    {
      "provision_ref": "10",
      "section": "Paragraph 10",
      "title": "",
      "content": "(क)     “आकस्मिक्‌कायन”्‌भन््‌नाले ्‌ भूकम्प, बाढी, पवहरो, आगलागी, िहािारी्‌िमता्‌\nप्राकृमतक्‌तथा्‌ गैरप्राकृमतक्‌ ववपद््‌ लगायतका्‌ आकस्मिक्‌ वा्‌ अप्रत्यास्ित्‌\nकारणबाट्‌ मसिनना्‌ भएको्‌ वविेष्‌ पररस्मथमतिा्‌ तत्काल्‌ गररने्‌ आकस्मिक्‌\nकायन्‌सम्झनु्‌पछन्‌।"
    },
    {
      "provision_ref": "11",
      "section": "Paragraph 11",
      "title": "",
      "content": "(ख)     “तोवकएको्‌वा्‌तोवकए्‌बिोस्िि”्‌भन््‌नाले ्‌यस्‌ऐन्‌अन्तगनत्‌बनेको्‌मनयििा्‌\nतोवकएको्‌वा्‌तोवकए्‌बिोस्िि्‌सम्झनु्‌पछन्‌।"
    },
    {
      "provision_ref": "12",
      "section": "Paragraph 12",
      "title": "",
      "content": "३.्‌    सङ्‌\nघीय्‌ आकस्मिक्‌ कोषको्‌ मथापनााः्‌ सङ्‌\nघीय्‌ आकस्मिक्‌ कोषको्‌ नािले ्‌ एउटा्‌ कोष्‌\nमथापना्‌गररएको्‌छ्‌।"
    },
    {
      "provision_ref": "13",
      "section": "Paragraph 13",
      "title": "",
      "content": "४.्‌   सङ्‌\nघीय्‌आकस्मिक्‌कोषिा्‌िम्िा्‌गररएको्‌रकिाः्‌सङ्‌\nघीय्‌सस्ञ््‌चत्‌कोषबाट्‌एक्‌करोड्‌\nरुपैंयााँ्‌स्झकी्‌त्यमतो्‌रकि्‌सङ्‌\nघीय्‌आकस्मिक्‌कोषिा्‌िम्िा्‌गररएको्‌छ्‌।"
    },
    {
      "provision_ref": "14",
      "section": "Paragraph 14",
      "title": "",
      "content": "५.्‌   सङ्‌\nघीय्‌आकस्मिक्‌कोषको्‌रकि्‌वृवि्‌गनन्‌सकनेाः्‌नेपाल्‌सरकारले ्‌नेपाल्‌रािपत्रिा्‌सूचना्‌\nप्रकािन्‌ गरी्‌ सङ्‌\nघीय्‌ आकस्मिक्‌ कोषिा्‌ रहने्‌ रकििा्‌ आवश्यकता्‌ अनुसार्‌ वृवि्‌ गनन्‌\nसकनेछ्‌।"
    },
    {
      "provision_ref": "15",
      "section": "Paragraph 15",
      "title": "",
      "content": "६.्‌   सङ्‌\nघीय्‌ आकस्मिक्‌ कोषको्‌ सञ्चालनाः्‌ सङ्‌\nघीय्‌ आकस्मिक्‌ कोषको्‌ सञ््‌\nचालन्‌ तोवकए्‌\nबिोस्िि्‌हुनेछ्‌।"
    },
    {
      "provision_ref": "16",
      "section": "Paragraph 16",
      "title": "",
      "content": "७.्‌   सङ्‌\nघीय्‌आकस्मिक्‌कोषको्‌रकि्‌खचन्‌ गनन्‌ सकनेाः्‌नेपाल्‌सरकारले ्‌ सङ्‌\nघीय्‌आकस्मिक्‌\nकोषिा्‌रहेको्‌रकिबाट्‌आकस्मिक्‌कायनका्‌लामग्‌खचन्‌गनन्‌सकनेछ्‌।्‌"
    },
    {
      "provision_ref": "17",
      "section": "Paragraph 17",
      "title": "",
      "content": "८.्‌   खचनको्‌रकि्‌सोधभनान्‌ गनु्‌न पनेाः्‌नेपाल्‌सरकारले्‌ दफा्‌७्‌बिोस्िि्‌सङ्‌\nघीय्‌आकस्मिक्‌\nकोषबाट्‌खचन्‌गरे को्‌रकि्‌ववमनयोिन्‌ऐन्‌बिोस्िि्‌प्रत्येक्‌आमथनक्‌वषनको्‌लामग्‌ववमनयोस्ित्‌\nरकिबाट्‌सोधभनान्‌गनु्‌न पनेछ्‌।्‌"
    },
    {
      "provision_ref": "18",
      "section": "Paragraph 18",
      "title": "",
      "content": "९.्‌   मनयि्‌बनाउने्‌अमधकाराः्‌यस्‌ऐनको्‌कायानन्वयन्‌गनन्‌नेपाल्‌सरकारले ्‌आवश्यक्‌मनयिहरु्‌\nबनाउन्‌सकनेछ्‌।"
    },
    {
      "provision_ref": "19",
      "section": "Paragraph 19",
      "title": "",
      "content": "१०.्‌ खारे िी्‌र्‌बचाउाः्‌(१)्‌्‌आकस्मिक्‌कोष्‌ऐन, २०१६्‌खारे ि्‌गररएको्‌छ्‌।"
    },
    {
      "provision_ref": "20",
      "section": "Paragraph 20",
      "title": "",
      "content": "(२)्‌आकस्मिक्‌कोष्‌ऐन, २०१६्‌बिोस्िि्‌भए्‌गरे का्‌काि्‌कारबाही्‌यसै ्‌ ऐन्‌\nबिोस्िि्‌भए्‌गरे को्‌िामननेछ्‌।"
    },
    {
      "provision_ref": "21",
      "section": "Paragraph 21",
      "title": "",
      "content": "(३)्‌ आकस्मिक्‌ कोष्‌ ऐन, २०१६्‌ बिोस्िि्‌ मथापना्‌ भएको्‌ आकस्मिक्‌ कोषिा्‌\nरहेको्‌रकि्‌यो्‌ऐन्‌प्रारम्भ्‌भए्‌पमछ्‌मवताः्‌सङ्‌\nघीय्‌आकस्मिक्‌कोषिा्‌सनेछ्‌।"
    }
  ],
  "definitions": []
}